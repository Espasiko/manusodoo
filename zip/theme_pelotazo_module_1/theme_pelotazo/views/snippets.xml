<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Theme snippets -->
    <template id="theme_snippets" inherit_id="website.snippets" name="Pelotazo Snippets">
        <xpath expr="//div[@id='snippet_structure']/div[hasclass('o_panel_body')]" position="inside">
            <t t-snippet="theme_pelotazo.s_banner" t-thumbnail="/theme_pelotazo/static/src/img/snippets/s_banner.jpg"/>
        </xpath>
    </template>
    
    <!-- Banner snippet template -->
    <template id="s_banner" name="Pelotazo Banner">
        <section class="s_banner">
            <div class="container">
                <div class="row">
                    <div class="col-lg-12">
                        <h1>Welcome to Pelotazo Theme</h1>
                        <p class="lead">A modern theme for your business</p>
                    </div>
                </div>
            </div>
        </section>
    </template>
</odoo>
